// ------------------------
// Libraries
// ------------------------
#include <ESP32Servo.h>

// ------------------------
// Variables that don't change
// ------------------------
int sensorPin = 15; // These pins may be different for your setup - check the pinout for your board
int btnPin = 18;
int drivePin = 19;
int dropPin = 21;
int ledPIN = 2;

int stop = 90; // swap these values if your servo moves in the opposite direction than expected
int fwd = 180; // swap these values if your servo moves in the opposite direction than expected
int rev = 0;

// Create servo objects
Servo driveServo;
Servo dropServo;

// ------------------------
// Variables that can change
// ------------------------
int btnState;           // current button state
int sensorState;        // current sensor state
int lastBtnState = LOW; // previous button state

int toggle = 0; // 0 = standby, 1 = run

unsigned long lastDebounceTime = 0; // Debounce variables
unsigned long debounceDelay = 50;

// ------------------------
// Setup
// ------------------------
void setup()
{
  pinMode(ledPIN, OUTPUT);
  pinMode(sensorPin, INPUT);
  pinMode(btnPin, INPUT);

  // Servo setup for ESP32
  driveServo.setPeriodHertz(50);
  driveServo.attach(drivePin, 500, 2400);

  dropServo.setPeriodHertz(50);
  dropServo.attach(dropPin, 500, 2400);

  Serial.begin(9600);
}

// ------------------------
// Main loop
// ------------------------
void loop()
{
  // Read inputs
  btnState = digitalRead(btnPin);
  sensorState = digitalRead(sensorPin);

  Serial.println(btnState); // Debug button state

  // ------------------------
  // Debounce logic
  // ------------------------

  // If button state changed, reset debounce timer
  if (btnState != lastBtnState)
  {
    lastDebounceTime = millis();
  }

  // If stable long enough, accept change
  if ((millis() - lastDebounceTime) > debounceDelay)
  {
    // Detect button press (LOW -> HIGH transition)
    if (btnState == HIGH && lastBtnState == LOW)
    {
      toggle = !toggle;

      Serial.print("Toggle = ");
      Serial.println(toggle);
    }
  }

  // Save state for next loop
  lastBtnState = btnState;

  // ------------------------
  // Mode selection
  // ------------------------

  if (toggle == 1)
  {
    run();
  }
  else
  {
    standby();
  }
}

// ------------------------
// Run behaviour
// ------------------------
void run()
{
  Serial.println("Run Mode");

  digitalWrite(ledPIN, HIGH);
  driveServo.write(fwd);

  if (sensorState == HIGH)
  {
    drop();
  }
}

// ------------------------
// Standby behaviour
// ------------------------
void standby()
{
  Serial.println("Standby Mode");

  digitalWrite(ledPIN, LOW);
  driveServo.write(stop);
}

// ------------------------
// Drop behaviour
// ------------------------
void drop()
{
  dropServo.write(90);
}