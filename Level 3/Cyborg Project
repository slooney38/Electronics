// ============================================================
// HELPERS
// ============================================================
void sendOK()
{
    server.send(200, "text/plain", "OK");
}

// ============================================================
// SERVER HANDLERS — SIMPLE IF/ELSE FORMAT
// ============================================================
void btnForward()
{
    String s = server.arg("s");
    if (s == "1")
    {
        digitalWrite(forwardPin, HIGH);
    }
    else
    {
        digitalWrite(forwardPin, LOW);
    }
    sendOK();
}

void btnLeft()
{
    String s = server.arg("s");
    if (s == "1")
    {
        digitalWrite(leftPin, HIGH);
    }
    else
    {
        digitalWrite(leftPin, LOW);
    }
    sendOK();
}

void btnRight()
{
    String s = server.arg("s");
    if (s == "1")
    {
        digitalWrite(rightPin, HIGH);
    }
    else
    {
        digitalWrite(rightPin, LOW);
    }
    sendOK();
}

void btnReverse()
{
    String s = server.arg("s");
    if (s == "1")
    {
        digitalWrite(reversePin, HIGH);
    }
    else
    {
        digitalWrite(reversePin, LOW);
    }
    sendOK();
}

void btnTest()
{
    String s = server.arg("s");
    if (s == "1")
    {
        digitalWrite(testPin, HIGH);
    }
    else
    {
        digitalWrite(testPin, LOW);
    }
    sendOK();
}

// ============================================================
// ROOT PAGE
// ============================================================
void root()
{
    server.send_P(200, "text/html", STUDENT_HTML);
}

// ============================================================
// SETUP
// ============================================================
void setup()
{
    Serial.begin(115200);

    // Configure pins as outputs
    pinMode(forwardPin, OUTPUT);
    pinMode(leftPin,    OUTPUT);
    pinMode(rightPin,   OUTPUT);
    pinMode(reversePin, OUTPUT);
    pinMode(testPin,    OUTPUT);

    // Start Access Point
    WiFi.softAP(apSSID, apPassword);
    Serial.print("AP mode IP: ");
    Serial.println(WiFi.softAPIP());

    // Setup URL handlers
    server.on("/", root);                 // Serves HTML page
    server.on("/f", btnForward);          // Forward button
    server.on("/l", btnLeft);             // Left button
    server.on("/r", btnRight);            // Right button
    server.on("/b", btnReverse);          // Reverse button
    server.on("/t", btnTest);             // TEST button

    // Start web server
    server.begin();
    Serial.println("Server started!");
}

// ============================================================
// LOOP
// ============================================================
void loop()
{
    server.handleClient();
}